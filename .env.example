# LLM provider: "openai" or "zen" (OpenCode Zen chat/completions models only)
LLM_PROVIDER=openai

# API key for the selected provider (server-only — not exposed to the browser)
# OpenAI: https://platform.openai.com/api-keys
# Zen: https://opencode.ai/auth
LLM_API_KEY=your-api-key-here

# Optional overrides (defaults depend on LLM_PROVIDER)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4

# Zen: use chat/completions models only (e.g. minimax-m2.5-free, kimi-k2.5, qwen3.5-plus)
# Do not use gpt-* or claude-* here — those use different Zen endpoints

# Legacy fallback if you still use VITE_OPENAI_API_KEY:
# VITE_OPENAI_API_KEY=your-openai-api-key-here

# Show optional email delivery UI after a reading (default: hidden)
PUBLIC_SHOW_EMAIL_OPTION=false

# Redis Cloud connection URL for shareable reading links
# Example: redis://default:password@redis-12345.c123.us-east-1-1.ec2.redns.redis-cloud.com:12345
REDIS_URL=redis://default:your-password@your-host:port

# How long shared readings are kept (seconds). Default: 90 days
# REDIS_READING_TTL_SECONDS=7776000

# Mailgun API key for sending reading emails (server-only)
# Get your API key from: https://app.mailgun.com/settings/api_security
MAILGUN_API_KEY=your-mailgun-api-key-here
